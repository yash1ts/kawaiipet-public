# Copy to apk-upload.env and fill in (apk-upload.env is gitignored).
# Service role key: Supabase Dashboard → Settings → API → service_role (secret).

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here
SUPABASE_STORAGE_BUCKET=apk
SUPABASE_APK_OBJECT_PATH=releases/kawaiipet.apk
